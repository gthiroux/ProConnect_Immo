{% extends 'base.html.twig' %}

{% block title %}Home index
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<link rel="stylesheet" href="{{ asset('styles/app.css') }}">

{% endblock %}
{% block body %}
	{% include "./partials/_nav.html.twig" %}
	<div class="CN-btn">
		<a href="{{ path('app_home_new') }}" class="btn">Create new</a>
	</div>

	<div class="ensemble">
		{% for home in homes %}
			<div class="card">
				<div class="home-image">
					<img src="{{ asset( home.image) }}" alt="{{ home.title }}" style="width:100%; height:100%; object-fit:cover; border-radius: .5rem .5rem 0 0;">
				</div>

				<div class="card-content">
					<div class="home-price">{{ home.price }}
						€</div>
					<div class="home-title">{{ home.title }}</div>
					<div class="home-adress">{{ home.adress }}</div>

					<div class="home-surface">
						<span class="icon-surface">📐</span>
						{{ home.surface }}
						m²
					</div>

					<p class="home-description">{{ home.description|slice(0, 100) }}...</p>
				</div>

				<div class="card-actions">
					<a href="{{ path('app_home_show', {'id': home.id}) }}" class="btn-show">Show</a>
					<a href="{{ path('app_home_edit', {'id': home.id}) }}" class="btn-edit">Edit</a>
				</div>
			</div>
		{% else %}
			<p>No records found</p>
		{% endfor %}
	</div>
	{% include "./partials/_footer.html.twig" %}
{% endblock %}
